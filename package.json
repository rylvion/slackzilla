{
  "name": "slackzilla",
  "version": "beta",
  "description": "slackatron mega 1x1x1x1 edition",
  "main": "src/bot.js",
  "scripts": {
    "start": "node src/bot.js",
    "dev": "node src/bot.js",
    "generate-manifest": "node scripts/generateManifest.js",
    "validate-manifest": "ajv validate -s schemas/manifest.schema.json -d manifest.json",
    "validate-commands": "ajv validate -s schemas/command.schema.json -d src/data/commands.json",
    "count-commands": "node scripts/countCommands.js"
  },
  "keywords": ["slack", "bot", "slackbot", "slackzilla"],
  "author": "@rylvion",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@slack/bolt": "^4.7.3",
    "dotenv": "^17.4.2",
    "octokit": "^5.0.5",
    "sodium-native": "^5.1.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1"
  }
}
