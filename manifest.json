{
  "display_information": {
    "name": "slackzilla",
    "description": "slackatron mega 1x1x1x1 edition",
    "long_description": "a fun slack bot that can do loads of things, from useful tools to random commands. type /help and see what slackzilla can do, with more commands and upgrades being added over time",
    "background_color": "#101f4d"
  },
  "features": {
    "bot_user": {
      "display_name": "Slackzilla",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/sz-8ball",
        "description": "ask the magic 8ball a question",
        "should_escape": false,
        "usage_hint": "<question>"
      },
      {
        "command": "/sz-base64",
        "description": "generates a base64 encoded string",
        "should_escape": false,
        "usage_hint": "<string>"
      },
      {
        "command": "/sz-calc",
        "description": "calculates a mathematical expression",
        "should_escape": false,
        "usage_hint": "<expression>"
      },
      {
        "command": "/sz-case",
        "description": "converts between text cases",
        "should_escape": false,
        "usage_hint": "<camel|pascal|snake|kebab> <text>"
      },
      {
        "command": "/sz-count",
        "description": "counts characters, words and lines",
        "should_escape": false,
        "usage_hint": "<text>"
      },
      {
        "command": "/sz-decode",
        "description": "decodes a base64 encoded string",
        "should_escape": false,
        "usage_hint": "<algorithm> <string>"
      },
      {
        "command": "/sz-echo",
        "description": "echoes the message you sent",
        "should_escape": false,
        "usage_hint": "<message>"
      },
      {
        "command": "/sz-fact",
        "description": "displays a fun fact",
        "should_escape": false
      },
      {
        "command": "/sz-hash",
        "description": "generates a hash of a string, default: sha256",
        "should_escape": false,
        "usage_hint": "<algorithm> <string>"
      },
      {
        "command": "/sz-help",
        "description": "displays all commands and their descriptions",
        "should_escape": false
      },
      {
        "command": "/sz-hug",
        "description": "HUG ME 🤗",
        "should_escape": false
      },
      {
        "command": "/sz-info",
        "description": "displays info about the bot (e.g. ver no., author, etc.)",
        "should_escape": false
      },
      {
        "command": "/sz-joke",
        "description": "😜sends a random joke",
        "should_escape": false
      },
      {
        "command": "/sz-meme",
        "description": "shows a random meme",
        "should_escape": false
      },
      {
        "command": "/sz-ping",
        "description": "idk js pongs ig",
        "should_escape": false
      },
      {
        "command": "/sz-quote",
        "description": "displays a random quote",
        "should_escape": false
      },
      {
        "command": "/sz-random",
        "description": "generates a random number between two numbers",
        "should_escape": false,
        "usage_hint": "<min> <max>"
      },
      {
        "command": "/sz-roll",
        "description": "rolls a dice",
        "should_escape": false,
        "usage_hint": "[side][n][rolls]+[modifier]"
      },
      {
        "command": "/sz-rps",
        "description": "play rock paper scissors with the bot",
        "should_escape": false,
        "usage_hint": "<rock|1 /paper|2 /scissors|3>"
      },
      {
        "command": "/sz-token",
        "description": "generates a secure random token",
        "should_escape": false,
        "usage_hint": "<length (default: 32)>"
      },
      {
        "command": "/sz-unix",
        "description": "converts between unix timestamp and human readable date",
        "should_escape": false,
        "usage_hint": "<timestamp|date>"
      },
      {
        "command": "/sz-uuid",
        "description": "generates a random uuid v4",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "commands"
      ]
    },
    "pkce_enabled": false
  },
  "settings": {
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "is_hosted": false,
    "token_rotation_enabled": false
  }
}
